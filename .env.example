# Core
SECRET_KEY=replace-with-strong-random-secret
DATABASE_URL=sqlite+aiosqlite:///./yourmove.db
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
ALLOWED_ORIGINS=["http://localhost:8000"]

# Optional production DB template
# DATABASE_URL=postgresql+asyncpg://yourmove:replace-password@db:5432/yourmove

# Optional Gemini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional SMTP login notification
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
